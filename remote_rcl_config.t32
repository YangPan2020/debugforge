; ============================================================
; remote_rcl_config.t32
; 远程机器上的 TRACE32 配置文件
;
; 使用方法 (在远程机器上):
;   t32mtc -c /path/to/remote_rcl_config.t32
;
; 或者追加到现有的 config.t32 文件中:
;   复制 RCL= 和 PORT= 部分到 config.t32 的空行之间
; ============================================================

; 必须: RCL 前后各一个空行

RCL=NETTCP
PORT=20000
PACKLEN=4096

; 允许多个客户端同时连接 (可选)
; RCLMULTIPLE=ENABLE
